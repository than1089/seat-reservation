# Database (local dev / e2e — Docker Compose overrides this with host `postgres` for the api service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seat_reservation?schema=public&connection_limit=20

# Clerk (create app at https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# API
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
WEBHOOK_SECRET=dev-webhook-secret-change-me
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3000

# E2E tests only
E2E_TEST_MODE=false
